<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Brilla Desde Adentro — LK.CO</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --rosa:#7D1A42;--rosa-med:#A82050;--rosa-cl:#C94068;
  --rosa-light:#F5E8EF;--dorado:#B8893E;--dorado-l:#EDD9A3;
  --crema:#FAF6F1;--blanco:#FFFFFF;--oscuro:#2A1520;--texto:#5A3C4A;
}
html{scroll-behavior:smooth}
body{font-family:'Montserrat',sans-serif;background:var(--crema);color:var(--oscuro);overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;z-index:0;pointer-events:none;
  background:radial-gradient(ellipse 70% 50% at 15% 15%,rgba(125,26,66,.05) 0%,transparent 60%),
             radial-gradient(ellipse 60% 50% at 88% 85%,rgba(184,137,62,.06) 0%,transparent 60%)}

/* PETALS */
.petal{position:fixed;border-radius:60% 0 60% 0;pointer-events:none;z-index:0;animation:drift linear infinite}
@keyframes drift{
  0%  {transform:translateY(105vh) rotate(0deg);opacity:0}
  8%  {opacity:1}
  90% {opacity:.5}
  100%{transform:translateY(-8vh) rotate(540deg);opacity:0}
}

/* HERO */
.hero{position:relative;z-index:1;min-height:100vh;display:flex;flex-direction:column;
  align-items:center;justify-content:center;text-align:center;padding:80px 32px 72px;overflow:hidden}
.ring{position:absolute;border-radius:50%;border:1px solid rgba(125,26,66,.07);pointer-events:none;
  top:50%;left:50%;animation:ringPulse ease-in-out infinite}
.r1{width:540px;height:540px;margin:-270px 0 0 -270px;animation-duration:7s}
.r2{width:380px;height:380px;margin:-190px 0 0 -190px;animation-duration:5s;animation-delay:1s}
.r3{width:240px;height:240px;margin:-120px 0 0 -120px;animation-duration:4s;animation-delay:.5s;border-color:rgba(184,137,62,.1)}
@keyframes ringPulse{0%,100%{transform:scale(1);opacity:.5}50%{transform:scale(1.05);opacity:1}}

.lkco{display:flex;align-items:center;gap:14px;margin-bottom:60px;opacity:0;animation:fadeIn .9s ease forwards .3s}
.lkco-line{width:38px;height:1px;background:var(--dorado)}
.lkco-name{font-size:11px;font-weight:600;letter-spacing:.6em;text-transform:uppercase;color:var(--dorado)}

.eyebrow{font-size:10px;font-weight:500;letter-spacing:.55em;text-transform:uppercase;
  color:var(--dorado);margin-bottom:20px;opacity:0;animation:fadeIn .9s ease forwards .5s}

.title{font-family:'Cormorant Garamond',serif;font-size:clamp(60px,12vw,116px);font-weight:300;
  line-height:.92;color:var(--rosa);opacity:0;animation:riseUp 1.2s cubic-bezier(.16,1,.3,1) forwards .7s}
.title em{display:block;font-style:italic;font-size:.82em;color:var(--rosa-cl);margin-top:4px}

.hero-tag{display:inline-block;margin:28px 0 20px;padding:7px 22px;
  border:1px solid rgba(125,26,66,.2);
  font-size:10px;font-weight:600;letter-spacing:.45em;text-transform:uppercase;
  color:var(--rosa);background:rgba(255,255,255,.6);backdrop-filter:blur(8px);
  opacity:0;animation:fadeIn .9s ease forwards .95s}

.hero-sub{font-family:'Cormorant Garamond',serif;font-size:clamp(16px,2.5vw,22px);
  font-style:italic;font-weight:300;color:var(--texto);max-width:500px;line-height:1.6;
  margin-bottom:44px;opacity:0;animation:fadeIn .9s ease forwards 1.1s}

.orn{display:flex;align-items:center;gap:10px;margin-bottom:44px;opacity:0;animation:fadeIn .9s ease forwards 1.25s}
.orn-l{width:52px;height:1px;background:rgba(125,26,66,.18)}
.orn-d{width:6px;height:6px;background:var(--dorado);transform:rotate(45deg)}
.orn-c{width:4px;height:4px;border-radius:50%;background:var(--rosa-cl)}

/* Date pill — solo aparece UNA VEZ aquí */
.date-pill{display:inline-flex;align-items:center;gap:24px;padding:16px 40px;
  border:1px solid rgba(125,26,66,.16);background:rgba(255,255,255,.68);backdrop-filter:blur(14px);
  opacity:0;animation:fadeIn .9s ease forwards 1.4s}
.date-item{text-align:center}
.date-label{font-size:9px;font-weight:600;letter-spacing:.4em;text-transform:uppercase;color:var(--dorado);margin-bottom:5px}
.date-value{font-family:'Cormorant Garamond',serif;font-size:17px;font-weight:600;color:var(--rosa);line-height:1.15}
.date-sep{width:1px;height:40px;background:rgba(125,26,66,.1)}

.scroll-hint{position:absolute;bottom:28px;display:flex;flex-direction:column;align-items:center;gap:7px;
  opacity:0;animation:fadeIn .9s ease forwards 2.1s}
.scroll-hint span{font-size:9px;letter-spacing:.4em;text-transform:uppercase;color:var(--texto);opacity:.35}
.sh-line{width:1px;height:42px;background:linear-gradient(to bottom,var(--dorado),transparent);animation:linePulse 2s ease-in-out infinite}
@keyframes linePulse{0%,100%{opacity:.3;transform:scaleY(.7)}50%{opacity:1;transform:scaleY(1)}}

/* CONTENT SECTIONS — z-index:1 para estar sobre fondo */
.content{position:relative;z-index:1}

/* ABOUT SECTION */
.about{padding:90px 32px;max-width:820px;margin:0 auto;text-align:center}
.sec-label{font-size:9px;font-weight:600;letter-spacing:.55em;text-transform:uppercase;color:var(--dorado);
  margin-bottom:18px;opacity:0;transition:opacity .8s ease,transform .8s ease;transform:translateY(18px)}
.sec-title{font-family:'Cormorant Garamond',serif;font-size:clamp(30px,5vw,48px);font-weight:300;line-height:1.2;
  color:var(--rosa);margin-bottom:24px;opacity:0;transition:opacity .9s ease .1s,transform .9s ease .1s;transform:translateY(22px)}
.sec-body{font-size:14px;line-height:2;color:var(--texto);font-weight:300;max-width:600px;margin:0 auto;
  opacity:0;transition:opacity .9s ease .2s,transform .9s ease .2s;transform:translateY(18px)}
.sec-label.vis,.sec-title.vis,.sec-body.vis{opacity:1;transform:translateY(0)}

/* FEMENINO BADGE */
.fem-badge{display:inline-flex;align-items:center;gap:10px;margin-top:32px;padding:11px 28px;
  background:var(--rosa);
  font-size:10px;font-weight:600;letter-spacing:.4em;text-transform:uppercase;color:var(--blanco);
  opacity:0;transition:opacity .9s ease .35s,transform .9s ease .35s;transform:translateY(14px)}
.fem-badge.vis{opacity:1;transform:translateY(0)}

/* TRAER SECTION */
.traer{background:var(--blanco);padding:80px 32px;border-top:1px solid rgba(125,26,66,.08);border-bottom:1px solid rgba(125,26,66,.08)}
.traer-inner{max-width:820px;margin:0 auto}
.traer-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:rgba(125,26,66,.08);margin-top:48px}
.traer-card{background:var(--blanco);padding:40px 36px;opacity:0;transition:opacity .7s ease,transform .7s ease,background .3s;transform:translateY(24px)}
.traer-card.vis{opacity:1;transform:translateY(0)}
.traer-card:hover{background:var(--rosa-light)}
.traer-card::after{content:'';display:block;width:0;height:2px;background:var(--dorado);margin-top:20px;transition:width .5s ease}
.traer-card:hover::after{width:100%}
.tc-icon{font-size:26px;margin-bottom:16px;display:block}
.tc-title{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:600;color:var(--rosa);margin-bottom:12px}
.tc-list{list-style:none;padding:0}
.tc-list li{font-size:13px;line-height:1.8;color:var(--texto);font-weight:300;padding:4px 0;
  border-bottom:1px solid rgba(125,26,66,.06);display:flex;align-items:flex-start;gap:8px}
.tc-list li:last-child{border-bottom:none}
.tc-list li::before{content:'✦';font-size:8px;color:var(--dorado);margin-top:5px;flex-shrink:0}

/* BOLSITA HIGHLIGHT */
.bolsita-hl{margin-top:48px;padding:36px 44px;border-left:3px solid var(--dorado);background:rgba(184,137,62,.05);
  opacity:0;transition:opacity .9s ease .3s,transform .9s ease .3s;transform:translateY(18px)}
.bolsita-hl.vis{opacity:1;transform:translateY(0)}
.bhl-title{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:600;color:var(--rosa);margin-bottom:10px}
.bhl-body{font-size:14px;line-height:1.9;color:var(--texto);font-weight:300}
.bhl-body strong{color:var(--rosa);font-weight:500}

/* QUOTE */
.quote-band{padding:80px 32px;background:var(--rosa);text-align:center;position:relative;overflow:hidden}
.quote-band::before{content:'"';position:absolute;top:-20px;left:50%;transform:translateX(-50%);
  font-family:'Cormorant Garamond',serif;font-size:300px;font-weight:300;color:rgba(255,255,255,.04);line-height:1;pointer-events:none}
.q-text{font-family:'Cormorant Garamond',serif;font-size:clamp(22px,4vw,40px);font-style:italic;font-weight:300;
  color:var(--blanco);line-height:1.5;max-width:700px;margin:0 auto 20px;position:relative;z-index:1}
.q-text strong{font-weight:600;color:var(--dorado-l)}
.q-author{font-size:11px;letter-spacing:.4em;text-transform:uppercase;color:rgba(255,255,255,.45);position:relative;z-index:1}

/* FOOTER */
footer{padding:28px 32px;background:var(--blanco);border-top:1px solid rgba(125,26,66,.08);
  display:flex;align-items:center;justify-content:space-between;position:relative;z-index:1}
.foot-brand{font-size:13px;font-weight:700;letter-spacing:.35em;color:var(--rosa)}
.foot-copy{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--texto);opacity:.4}

@keyframes fadeIn{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
@keyframes riseUp{from{opacity:0;transform:translateY(38px) scale(.97)}to{opacity:1;transform:translateY(0) scale(1)}}

@media(max-width:640px){
  .traer-grid{grid-template-columns:1fr}
  .r1{width:300px;height:300px;margin:-150px 0 0 -150px}
  .r2{width:200px;height:200px;margin:-100px 0 0 -100px}
  .r3{display:none}
  .date-pill{flex-wrap:wrap;justify-content:center;gap:16px;padding:18px 28px}
  .date-sep{width:60px;height:1px}
  footer{flex-direction:column;gap:8px;text-align:center}
  .bolsita-hl{padding:28px 24px}
}
</style>
</head>
<body>

<script>
  const cols=['#7D1A42','#A82050','#C94068','#B8893E','#F5E8EF'];
  for(let i=0;i<20;i++){
    const p=document.createElement('div');
    p.className='petal';
    const s=Math.random()*7+4;
    p.style.cssText=`width:${s}px;height:${s*1.5}px;left:${Math.random()*100}%;`
      +`background:${cols[Math.floor(Math.random()*cols.length)]};`
      +`opacity:${Math.random()*.28+.08};`
      +`animation-duration:${Math.random()*18+13}s;`
      +`animation-delay:${Math.random()*15}s;`;
    document.body.appendChild(p);
  }
</script>

<!-- ══ HERO ══════════════════════════════════════════ -->
<section class="hero">
  <div class="ring r1"></div>
  <div class="ring r2"></div>
  <div class="ring r3"></div>

  <div class="lkco">
    <div class="lkco-line"></div>
    <span class="lkco-name">LK.CO</span>
    <div class="lkco-line"></div>
  </div>

  <p class="eyebrow">Taller de Imagen Personal</p>

  <h1 class="title">
    Brilla<br><em>desde adentro</em>
  </h1>

  <span class="hero-tag"></span>

  <p class="hero-sub">
    Un espacio creado especialmente para ti —<br>
    íntimo, transformador y lleno de sorpresas.
  </p>

  <div class="orn">
    <div class="orn-l"></div><div class="orn-c"></div>
    <div class="orn-d"></div>
    <div class="orn-c"></div><div class="orn-l"></div>
  </div>

  <div class="date-pill">
    <div class="date-item">
      <div class="date-label">Fecha</div>
      <div class="date-value">Miércoles<br>4 Mar 2026</div>
    </div>
    <div class="date-sep"></div>
    <div class="date-item">
      <div class="date-label">Hora</div>
      <div class="date-value">10:00 AM<br>– 12:00 M</div>
    </div>
    <div class="date-sep"></div>
    <div class="date-item">
      <div class="date-label">Lugar</div>
      <div class="date-value">Salón de<br>Capacitaciones LK</div>
    </div>
  </div>

  <div class="scroll-hint">
    <span></span>
    <div class="sh-line"></div>
  </div>
</section>

<div class="content">

  <!-- ══ ABOUT ══════════════════════════════════════ -->
  <div class="about">
    <p class="sec-label">La experiencia</p>
    <h2 class="sec-title">Un taller que va <em>más allá</em> de lo que imaginas</h2>
    <p class="sec-body">
      En LK.CO creemos que la imagen personal es mucho más que ropa y maquillaje.
      Es la historia que cuentas antes de hablar. Es confianza, presencia y autenticidad.<br><br>
      Este taller es un espacio íntimo, solo para nosotras — donde vamos a explorar
      juntas cómo proyectar lo mejor de cada una con herramientas reales, prácticas
      y pensadas para el día a día en la oficina.
    </p>
    <div class="fem-badge">
      🌸 &nbsp; Exclusivo para el equipo femenino de LK.CO &nbsp; 🌸
    </div>
  </div>

  <!-- ══ QUÉ TRAER ════════════════════════════════════ -->
  <div class="traer">
    <div class="traer-inner">
      <p class="sec-label" style="text-align:center">Prepárate</p>
      <h2 class="sec-title" style="text-align:center">Lo que necesitas traer</h2>

      <div class="traer-grid">
        <div class="traer-card" style="transition-delay:0s">
          <span class="tc-icon">💄</span>
          <div class="tc-title">Tu bolsita de maquillaje</div>
          <ul class="tc-list">
            <li>La que usas normalmente — no necesitas más</li>
            <li>Base, corrector o polvos</li>
            <li>Máscara de pestañas</li>
            <li>Tu labial favorito</li>
            
          </ul>
        </div>

        <div class="traer-card" style="transition-delay:.15s">
          <span class="tc-icon">✨</span>
          <div class="tc-title">Experiencia completa</div>
          <ul class="tc-list">
            <li>Puedes venir con el rostro limpio</li>
            <li>Te maquillarás desde cero en el taller</li>
            <li>Recibirás asesoría personalizada</li>
            <li>Vivirás una transformación real</li>
            <li>Es opcional — pero totalmente vale la pena</li>
          </ul>
        </div>
      </div>

      <div class="bolsita-hl">
        <div class="bhl-title">Habrán muchas sorpresas y premios.🌸</div>
        <p class="bhl-body">
        </p>
      </div>
    </div>
  </div>

  <!-- ══ QUOTE ════════════════════════════════════════ -->
  <div class="quote-band">
    <p class="q-text">
      "La imagen que proyectas es<br>
      <strong>la primera historia que cuentas</strong><br>
      sin decir una sola palabra."
    </p>
    <p class="q-author">Rebeca Rodríguez &nbsp;·&nbsp; LK.CO</p>
  </div>

  <!-- ══ FOOTER ════════════════════════════════════════ -->
  <footer>
    <span class="foot-brand">LK.CO</span>
    <span class="foot-copy">Brilla desde adentro &nbsp;·&nbsp; Marzo 2026</span>
  </footer>

</div>

<script>
  const obs=new IntersectionObserver(entries=>{
    entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('vis')})
  },{threshold:.15});
  document.querySelectorAll('.sec-label,.sec-title,.sec-body,.fem-badge,.traer-card,.bolsita-hl')
    .forEach(el=>obs.observe(el));
</script>
</body>
</html>
